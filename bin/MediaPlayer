import java.awt.*;
import java.io.*;
import java.util.*;
import javax.sound.sampled.*;
import javax.swing.*;

public class MediaPlayer extends JFrame {
    public static void main(String[] args) throws IOException {
        MediaPlayer w = new MediaPlayer("AndrewBotics Playlist");
    }
    Font DEFAULTFONT = new Font("Verdana", Font.PLAIN, 12);
    ArrayList<File> SONGS = new ArrayList<>();

    int SONGINDEX = -1;
    Clip CURRENTSONG;
    long LASTPOSITION;

    JButton PLAY;
    JButton NEXTSONG;
    JButton PREVSONG;

    boolean PAUSED = false;

    public MediaPlayer(String name) throws IOException {
        super(name);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setResizable(false);
        setSize(300, 400);
        setLayout(null);

        addImage("thumbnail.png");

        loadSongs();
        Collections.shuffle(SONGS);

        PLAY = new JButton("PAUSE");
        PLAY.addActionListener(e -> pausePlay());
        add(PLAY);
        PLAY.setBounds(100, 275, 75, 50);

        NEXTSONG = new JButton(">");
        NEXTSONG.addActionListener(e -> nextSong());
        add(NEXTSONG);
        NEXTSONG.setBounds(185, 275, 50, 50);

        PREVSONG = new JButton("<");
        PREVSONG.addActionListener(e -> backSong());
        add(PREVSONG);
        PREVSONG.setBounds(40, 275, 50, 50);

        playNextSong();

        setVisible(true);
    }
    void addImage(String image){
        int W = 225;
        int H = 225;
        ImageIcon fileIcon = new ImageIcon(image);
        Image output = fileIcon.getImage().getScaledInstance(W, H, Image.SCALE_SMOOTH);
        ImageIcon scaled = new ImageIcon(output);
        JLabel imageLabel = new JLabel(scaled);
        imageLabel.setBounds(25, 25, W, H);
        add(imageLabel);
    }
    void nextSong(){
        CURRENTSONG.stop();
        CURRENTSONG.close();
        playNextSong();
    }
    void backSong(){
        CURRENTSONG.stop();
        CURRENTSONG.close();
        SONGINDEX = (SONGINDEX+SONGS.size()-2)%SONGS.size();
        playNextSong();
    }
    void pausePlay(){
        if (CURRENTSONG!=null) {
            if (CURRENTSONG.isRunning()) {
                LASTPOSITION = CURRENTSONG.getMicrosecondPosition();
                PAUSED = true;
                CURRENTSONG.stop();
                PLAY.setText("PLAY");
            }
            else {
                CURRENTSONG.setMicrosecondPosition(LASTPOSITION);
                PAUSED = false;
                CURRENTSONG.start();
                PLAY.setText("PAUSE");
            }
        }
    }
    void playNextSong() {
        try {
            SONGINDEX = (SONGINDEX+1)%SONGS.size();
            File soundFile = SONGS.get(SONGINDEX);
            AudioInputStream audioIn = AudioSystem.getAudioInputStream(soundFile);
            CURRENTSONG = AudioSystem.getClip();
            CURRENTSONG.open(audioIn);
            CURRENTSONG.start();
            CURRENTSONG.addLineListener(e->{
                if (e.getType()==LineEvent.Type.STOP && e.getFramePosition()==CURRENTSONG.getFrameLength()){
                    System.out.println("FINISHED");
                    try {
                        Thread.sleep(500);
                    } catch (InterruptedException ex) {
                        throw new RuntimeException(ex);
                    }
                    nextSong();
                }
            });
        }
        catch (Exception e){
            System.out.println(Arrays.toString(AudioSystem.getAudioFileTypes()));
            e.printStackTrace();
        }
    }
    void loadSongs(){
        File f = new File("Songs");
        SONGS.addAll(Arrays.asList(f.listFiles()));
    }
}

